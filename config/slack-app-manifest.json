{
  "display_information": {
    "name": "QBO Copilot",
    "description": "QuickBooks Online assistant for accounting operations and client onboarding",
    "background_color": "#2c5f2d"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "QBO Copilot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/qbo",
        "description": "Query QuickBooks Online",
        "usage_hint": "[invoices|customers|accounts|help]",
        "should_escape": false
      }
    ],
    "shortcuts": [
      {
        "name": "Convert to Case",
        "type": "message",
        "callback_id": "convert_to_case",
        "description": "Convert this message into a trackable case"
      },
      {
        "name": "Request Documents",
        "type": "message",
        "callback_id": "request_docs",
        "description": "Request documents from client"
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "channels:manage",
        "channels:join",
        "chat:write",
        "commands",
        "files:read",
        "files:write",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "pins:write",
        "reactions:read",
        "reactions:write",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "app_home_opened",
        "message.im",
        "message.channels",
        "message.groups"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
